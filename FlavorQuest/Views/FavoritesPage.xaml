<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:FlavorQuest.ViewModels"
             xmlns:models="clr-namespace:FlavorQuest.Models"
             x:Class="FlavorQuest.Views.FavoritesPage"
             x:DataType="vm:FavoritesViewModel"
             Title="{Binding Title}">

    <Grid RowDefinitions="Auto,*" Padding="16">
        <HorizontalStackLayout Grid.Row="0" Spacing="12" Margin="0,0,0,12">
            <Label Text="❤️" FontSize="24" VerticalOptions="Center" />
            <Label Text="My Favorites" FontSize="24" FontAttributes="Bold" VerticalOptions="Center" />
        </HorizontalStackLayout>

        <RefreshView Grid.Row="1"
                     IsRefreshing="{Binding IsRefreshing}"
                     Command="{Binding RefreshCommand}">
            <Grid>
                <CollectionView ItemsSource="{Binding FavoriteRecipes}"
                                SelectionMode="None"
                                IsVisible="{Binding IsEmpty, Converter={StaticResource InverseBoolConverter}}">
                    <CollectionView.EmptyView>
                        <VerticalStackLayout VerticalOptions="Center"
                                             HorizontalOptions="Center"
                                             Spacing="12" Padding="32">
                            <Label Text="💝" FontSize="64" HorizontalOptions="Center" />
                            <Label Text="No favorites yet" FontSize="20" FontAttributes="Bold" HorizontalOptions="Center" />
                            <Label Text="Browse recipes and tap the heart icon to save your favorites!"
                                   FontSize="14" Opacity="0.6" HorizontalOptions="Center" HorizontalTextAlignment="Center" />
                            <Button Text="Browse Recipes"
                                    Clicked="OnBrowseRecipesClicked"
                                    BackgroundColor="{StaticResource Primary}"
                                    TextColor="White"
                                    CornerRadius="8"
                                    Margin="0,8,0,0" />
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="12" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:Recipe">
                            <SwipeView>
                                <SwipeView.LeftItems>
                                    <SwipeItems>
                                        <SwipeItem Text="🗑 Remove"
                                                   BackgroundColor="#F44336"
                                                   Command="{Binding Source={RelativeSource AncestorType={x:Type vm:FavoritesViewModel}}, Path=RemoveFavoriteCommand}"
                                                   CommandParameter="{Binding .}" />
                                    </SwipeItems>
                                </SwipeView.LeftItems>
                                <Frame Padding="12" CornerRadius="12"
                                       BorderColor="{StaticResource Gray200}"
                                       BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray950}}">
                                    <Frame.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:FavoritesViewModel}}, Path=GoToRecipeCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Frame.GestureRecognizers>
                                    <Grid ColumnDefinitions="70,*" ColumnSpacing="12">
                                        <Frame Grid.Column="0" CornerRadius="8" Padding="0"
                                               BackgroundColor="{Binding DifficultyColor}"
                                               HeightRequest="70" WidthRequest="70">
                                            <Label Text="❤️" FontSize="28"
                                                   HorizontalOptions="Center" VerticalOptions="Center"
                                                   TextColor="White" />
                                        </Frame>
                                        <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                                            <Label Text="{Binding Name}" FontSize="16" FontAttributes="Bold"
                                                   LineBreakMode="TailTruncation" />
                                            <Label Text="{Binding Description}" FontSize="13" Opacity="0.6"
                                                   MaxLines="2" LineBreakMode="TailTruncation" />
                                            <HorizontalStackLayout Spacing="12">
                                                <Label Text="{Binding TotalTimeDisplay, StringFormat='⏱ {0}'}"
                                                       FontSize="12" Opacity="0.7" />
                                                <Label Text="{Binding Difficulty, StringFormat='📊 {0}'}"
                                                       FontSize="12" Opacity="0.7" />
                                                <Label Text="{Binding Category}" FontSize="12" Opacity="0.7" />
                                            </HorizontalStackLayout>
                                        </VerticalStackLayout>
                                    </Grid>
                                </Frame>
                            </SwipeView>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
                <Button Text="Clear All"
                        Command="{Binding ClearAllFavoritesCommand}"
                        BackgroundColor="#F44336" TextColor="White"
                        CornerRadius="24" FontSize="13"
                        HeightRequest="44" WidthRequest="120"
                        HorizontalOptions="End" VerticalOptions="End"
                        Margin="0,0,4,4"
                        IsVisible="{Binding IsEmpty, Converter={StaticResource InverseBoolConverter}}" />
            </Grid>
        </RefreshView>
    </Grid>
</ContentPage>
