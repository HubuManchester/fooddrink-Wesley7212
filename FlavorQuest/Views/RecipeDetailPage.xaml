<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:FlavorQuest.ViewModels"
             xmlns:models="clr-namespace:FlavorQuest.Models"
             x:Class="FlavorQuest.Views.RecipeDetailPage"
             x:DataType="vm:RecipeDetailViewModel"
             Title="{Binding Title}">

    <Shell.NavBarIsVisible>True</Shell.NavBarIsVisible>

    <ScrollView>
        <VerticalStackLayout Spacing="16" Padding="16">
            <Button Text="← Back"
                    Command="{Binding GoBackCommand}"
                    BackgroundColor="Transparent"
                    TextColor="{StaticResource Primary}"
                    FontSize="14" HorizontalOptions="Start"
                    Padding="8,4" />
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                              HorizontalOptions="Center" Color="{StaticResource Primary}" />

            <VerticalStackLayout Spacing="8" IsVisible="{Binding IsNotBusy}">
                <Frame HeightRequest="200" CornerRadius="12" Padding="0"
                       BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#2A2A2A}"
                       BorderColor="Transparent">
                    <Label Text="🍽️" FontSize="80" HorizontalOptions="Center" VerticalOptions="Center" />
                </Frame>
                <Grid ColumnDefinitions="*,Auto">
                    <Label Text="{Binding Recipe.Name}" FontSize="24" FontAttributes="Bold" />
                    <Button Grid.Column="1" Command="{Binding ToggleFavoriteCommand}"
                            BackgroundColor="Transparent" BorderWidth="0"
                            WidthRequest="48" HeightRequest="48"
                            Text="{Binding Recipe.IsFavorite, StringFormat='{0}'}">
                        <Button.Triggers>
                            <DataTrigger TargetType="Button" Binding="{Binding Recipe.IsFavorite}" Value="True">
                                <Setter Property="Text" Value="❤️" />
                            </DataTrigger>
                            <DataTrigger TargetType="Button" Binding="{Binding Recipe.IsFavorite}" Value="False">
                                <Setter Property="Text" Value="🤍" />
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>
                </Grid>
                <Label Text="{Binding Recipe.Description}" FontSize="15" Opacity="0.7" />
                <FlexLayout Wrap="Wrap" JustifyContent="Start" AlignItems="Center">
                    <Frame Padding="8,4" CornerRadius="8" Margin="0,0,8,4"
                           BackgroundColor="{AppThemeBinding Light=#E8F5E9, Dark=#1B5E20}"
                           BorderColor="Transparent">
                        <Label Text="{Binding Recipe.TotalTimeDisplay, StringFormat='⏱ {0}'}" FontSize="12" />
                    </Frame>
                    <Frame Padding="8,4" CornerRadius="8" Margin="0,0,8,4"
                           BackgroundColor="{Binding Recipe.DifficultyColor}" BorderColor="Transparent">
                        <Label Text="{Binding Recipe.Difficulty, StringFormat='📊 {0}'}"
                               FontSize="12" TextColor="White" />
                    </Frame>
                    <Frame Padding="8,4" CornerRadius="8" Margin="0,0,8,4"
                           BackgroundColor="{AppThemeBinding Light=#E3F2FD, Dark=#0D47A1}"
                           BorderColor="Transparent">
                        <Label Text="{Binding Recipe.Servings, StringFormat='👥 {0} servings'}" FontSize="12" />
                    </Frame>
                    <Frame Padding="8,4" CornerRadius="8" Margin="0,0,8,4"
                           BackgroundColor="{AppThemeBinding Light=#FFF3E0, Dark=#E65100}"
                           BorderColor="Transparent">
                        <Label Text="{Binding Recipe.Category}" FontSize="12" />
                    </Frame>
                </FlexLayout>
                <FlexLayout Wrap="Wrap" BindableLayout.ItemsSource="{Binding Recipe.Tags}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="x:String">
                            <Frame Padding="8,4" CornerRadius="8" Margin="0,0,6,4"
                                   BackgroundColor="{AppThemeBinding Light=#F3E5F5, Dark=#4A148C}"
                                   BorderColor="Transparent">
                                <Label Text="{Binding .}" FontSize="11" />
                            </Frame>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </FlexLayout>
            </VerticalStackLayout>

            <!-- Ingredients -->
            <VerticalStackLayout Spacing="8" IsVisible="{Binding IsNotBusy}">
                <Grid ColumnDefinitions="*,Auto">
                    <Label Text="🧂 Ingredients" FontSize="20" FontAttributes="Bold" VerticalOptions="Center" />
                    <Button Grid.Column="1" Text="🔊 Read Aloud"
                            Command="{Binding ReadIngredientsCommand}"
                            BackgroundColor="#FF6B35" TextColor="White"
                            FontSize="14" Padding="12,6" CornerRadius="8">
                        <Button.Triggers>
                            <DataTrigger TargetType="Button" Binding="{Binding IsTtsSpeaking}" Value="True">
                                <Setter Property="Text" Value="⏹ Stop" />
                                <Setter Property="BackgroundColor" Value="#F44336" />
                                <Setter Property="Command" Value="{Binding StopSpeakingCommand}" />
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>
                </Grid>
                <CollectionView ItemsSource="{Binding Recipe.Ingredients}" SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="x:String">
                            <HorizontalStackLayout Spacing="8" Padding="0,4">
                                <Label Text="•" FontSize="16" VerticalOptions="Center"
                                       TextColor="{StaticResource Primary}" />
                                <Label Text="{Binding .}" FontSize="14" VerticalOptions="Center" />
                            </HorizontalStackLayout>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>

            <!-- Instructions -->
            <VerticalStackLayout Spacing="8" IsVisible="{Binding IsNotBusy}">
                <Grid ColumnDefinitions="*,Auto">
                    <Label Text="📝 Instructions" FontSize="20" FontAttributes="Bold" VerticalOptions="Center" />
                    <Button Grid.Column="1" Text="🔊 Read Aloud"
                            Command="{Binding ReadInstructionsCommand}"
                            BackgroundColor="#2196F3" TextColor="White"
                            FontSize="14" Padding="12,6" CornerRadius="8">
                        <Button.Triggers>
                            <DataTrigger TargetType="Button" Binding="{Binding IsTtsSpeaking}" Value="True">
                                <Setter Property="Text" Value="⏹ Stop" />
                                <Setter Property="BackgroundColor" Value="#F44336" />
                                <Setter Property="Command" Value="{Binding StopSpeakingCommand}" />
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>
                </Grid>
                <CollectionView ItemsSource="{Binding Recipe.Instructions}" SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="x:String">
                            <Frame Padding="12" CornerRadius="8" Margin="0,4"
                                   BackgroundColor="{AppThemeBinding Light=#FAFAFA, Dark=#1E1E1E}"
                                   BorderColor="{StaticResource Gray200}">
                                <HorizontalStackLayout Spacing="10">
                                    <Frame CornerRadius="12" Padding="6,2"
                                           BackgroundColor="{StaticResource Primary}"
                                           BorderColor="Transparent" VerticalOptions="Center"
                                           MinimumWidthRequest="24">
                                        <Label Text="" FontSize="12" FontAttributes="Bold"
                                               TextColor="White" HorizontalOptions="Center" />
                                    </Frame>
                                    <Label Text="{Binding .}" FontSize="14" VerticalOptions="Center" />
                                </HorizontalStackLayout>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>

            <!-- Nutrition -->
            <VerticalStackLayout Spacing="8" IsVisible="{Binding IsNotBusy}">
                <Label Text="📊 Nutrition (per serving)" FontSize="20" FontAttributes="Bold" />
                <Frame Padding="16" CornerRadius="12" BorderColor="Transparent"
                       BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#2A2A2A}">
                    <Grid ColumnDefinitions="*,*,*,*" RowDefinitions="Auto" ColumnSpacing="8">
                        <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center">
                            <Label Text="{Binding Recipe.Nutrition.Calories}" FontSize="22" FontAttributes="Bold"
                                   HorizontalOptions="Center" />
                            <Label Text="kcal" FontSize="11" Opacity="0.6" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center">
                            <Label Text="{Binding Recipe.Nutrition.ProteinGrams, StringFormat='{0:F0}g'}"
                                   FontSize="22" FontAttributes="Bold" HorizontalOptions="Center" />
                            <Label Text="Protein" FontSize="11" Opacity="0.6" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center">
                            <Label Text="{Binding Recipe.Nutrition.CarbsGrams, StringFormat='{0:F0}g'}"
                                   FontSize="22" FontAttributes="Bold" HorizontalOptions="Center" />
                            <Label Text="Carbs" FontSize="11" Opacity="0.6" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="3" HorizontalOptions="Center">
                            <Label Text="{Binding Recipe.Nutrition.FatGrams, StringFormat='{0:F0}g'}"
                                   FontSize="22" FontAttributes="Bold" HorizontalOptions="Center" />
                            <Label Text="Fat" FontSize="11" Opacity="0.6" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Grid>
                </Frame>
            </VerticalStackLayout>

            <!-- Suggestions -->
            <VerticalStackLayout Spacing="8" IsVisible="{Binding IsNotBusy}">
                <Label Text="💡 You Might Also Like" FontSize="20" FontAttributes="Bold" />
                <CollectionView ItemsSource="{Binding Suggestions}" SelectionMode="None">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Horizontal" ItemSpacing="12" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:Recipe">
                            <Frame WidthRequest="160" Padding="12" CornerRadius="12"
                                   BorderColor="{StaticResource Gray200}"
                                   BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray950}}">
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:RecipeDetailViewModel}}, Path=GoToSuggestionCommand}"
                                        CommandParameter="{Binding .}" />
                                </Frame.GestureRecognizers>
                                <VerticalStackLayout Spacing="6">
                                    <Label Text="🍽️" FontSize="32" HorizontalOptions="Center" />
                                    <Label Text="{Binding Name}" FontSize="14" FontAttributes="Bold"
                                           LineBreakMode="TailTruncation" MaxLines="2" />
                                    <HorizontalStackLayout Spacing="8">
                                        <Label Text="{Binding TotalTimeDisplay, StringFormat='⏱ {0}'}"
                                               FontSize="11" Opacity="0.6" />
                                        <Label Text="{Binding Difficulty, StringFormat='📊 {0}'}"
                                               FontSize="11" Opacity="0.6" />
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>

            <Button Text="{Binding Recipe.Category, StringFormat='See more {0} recipes →'}"
                    Command="{Binding GoToCategoryCommand}"
                    BackgroundColor="Transparent" TextColor="{StaticResource Primary}"
                    FontSize="14" HorizontalOptions="Center" IsVisible="{Binding IsNotBusy}" />
            <BoxView HeightRequest="16" Color="Transparent" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
